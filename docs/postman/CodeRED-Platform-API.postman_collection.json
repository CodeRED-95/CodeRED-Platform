{
  "info": {
    "name": "CodeRED Platform API v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://platform.codered.host"
    },
    {
      "key": "agency_token",
      "value": ""
    },
    {
      "key": "dni_token",
      "value": ""
    },
    {
      "key": "dni",
      "value": "12345678"
    }
  ],
  "item": [
    {
      "name": "Consulta de agencias",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{agency_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/agencias?per_page=20",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "agencias"
          ],
          "query": [
            {
              "key": "per_page",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "Detalle de agencia",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{agency_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/agencias/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "agencias",
            "1"
          ]
        }
      }
    },
    {
      "name": "Consulta DNI",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{dni_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/dni/{{dni}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "dni",
            "{{dni}}"
          ]
        }
      }
    }
  ]
}
